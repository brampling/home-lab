# the rest (together with controlplane-patch.yaml).
talos/secrets.yaml
talos/talosconfig
talos/controlplane.yaml
talos/worker.yaml
talos/cp.yaml

# Local kubeconfig, if ever written into the repo
kubeconfig
*.kubeconfig
